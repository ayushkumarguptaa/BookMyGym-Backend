<div><p class="text-center text-3xl">TOP EXERCISES</p></div>
<div class="">

      <div class="flex flex-wrap">

  <% for(let val of topexercises){ %>
  <!-- <p><%= val.title %></p> -->


  <div class="col ml-[3%] max-w-[15em] h-[15em] border-bottom">
    <div class="card h-100">
      <img src="<%= val.image %>" class="card-img-top" alt="...">
      <div class="card-body">
        <h5 class="card-title"> <%= val.title %></h5>
        <!-- <p class="card-text">This is a short card.</p> -->
      </div>
    </div>
  </div>



<% } %>

</div>
<div>
  <p class="text-center"><a href="/gymnastic/top-exercises" class="link-primary">View More <i class="fa-solid fa-arrow-down"></i></a></p>
</div>

</div>
<hr>
<br><br>

<div><p class="text-center text-3xl">Popular Equipments</p></div>

<div class="">
<div class="flex flex-wrap p-3 h-[27em]">

  <% for(let val of equipments){ %>
  <!-- <p><%= val.title %></p> -->


  <div class="col ml-[1%] min-w-[18em] h-[20em] border-bottom">
    <div class="card h-80">
      <div class="h-80">
        <img src="<%= val.image %>" class="card-img-top h-[100%]" alt="...">
      </div>
      <div class="card-body">
        <h5 class="card-title"> <%= val.title %></h5>
        <!-- <p class="card-text">This is a short card.</p> -->
      </div>
    </div>
  </div>



<% } %>

</div>

<div>
